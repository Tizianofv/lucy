# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno de Lucy.
# Copiá este archivo a .env para correr en local (el .env NO se sube a git).
# En Railway, estos mismos nombres se cargan en Variables del servicio.
# ─────────────────────────────────────────────────────────────

# Token del bot de Telegram (de @BotFather)
TELEGRAM_TOKEN=123456:ABC-DEF...

# Tu chat ID (de @userinfobot). Lucy SOLO le responde a este chat.
CHAT_ID_DUENO=000000000

# Conexión a Postgres. Railway la inyecta sola como DATABASE_URL.
# En local podés apuntar a la misma base de Railway o a una local.
DATABASE_URL=postgresql://usuario:clave@host:5432/railway

# API key de Gemini (de https://aistudio.google.com)
GEMINI_API_KEY=AIza...
